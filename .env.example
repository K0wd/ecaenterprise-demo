# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
#
# NOTE FROM THE AUTHOR: The author is fully aware that committing real credentials —
# even in an example file — is not something you would do on a real project. These are
# SauceDemo's *public* demo credentials and are exposed here in `.env.example` purely
# for the sake of this demo, so reviewers can run the suite with zero setup. In a real
# project these values would come from repository secrets / a vault and this file would
# hold placeholders only. The secure pattern still holds: source code reads from env,
# never from hardcoded values.

BASE_URL=https://www.saucedemo.com
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce
